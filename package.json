{
  "name": "barebrowse",
  "version": "0.19.2",
  "description": "Authenticated web browsing for autonomous agents via CDP. URL in, pruned ARIA snapshot out.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hamr0/barebrowse.git"
  },
  "homepage": "https://github.com/hamr0/barebrowse#readme",
  "bugs": "https://github.com/hamr0/barebrowse/issues",
  "type": "module",
  "main": "src/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    },
    "./bareagent": {
      "types": "./types/bareagent.d.ts",
      "default": "./src/bareagent.js"
    }
  },
  "bin": {
    "barebrowse": "./cli.js"
  },
  "files": [
    "src/",
    "types/",
    "cli.js",
    "mcp-server.js",
    "barebrowse.context.md",
    "README.md",
    "CHANGELOG.md",
    "NOTICE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --test test/unit/*.test.js test/integration/*.test.js",
    "test:unit": "node --test test/unit/*.test.js",
    "test:integration": "node --test test/integration/*.test.js",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc",
    "prepublishOnly": "npm run build:types"
  },
  "keywords": [
    "browser",
    "cdp",
    "chromium",
    "aria",
    "accessibility",
    "web-scraping",
    "agent",
    "mcp",
    "headless"
  ],
  "optionalDependencies": {
    "wearehere": "1.0.0"
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "ws": "^8.21.0"
  }
}
