.env
.env.*
!.env.example

# Editor / tooling
.idea/
.aurora/
*.log

# OS
.DS_Store

# Agent / IDE scratch — never commit (per hamr0 LIBRARY_CONVENTIONS §7)
.claude/
.litectx/
.idea/
